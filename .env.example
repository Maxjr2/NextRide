# ─── NextRide — Docker Compose environment ────────────────────────────────────
#
# Copy this file to .env and adjust values before running:
#
#   Full stack (Postgres + Keycloak + API + Web):
#     docker compose up
#
#   Mock mode (no DB, no Keycloak — in-memory data, role switcher in UI):
#     docker compose -f docker-compose.mock.yml up
#
# .env is git-ignored; this file is the committed reference.

# ─── Ports ────────────────────────────────────────────────────────────────────
# Change these if the defaults clash with something already running locally.

DB_PORT=5432          # PostgreSQL host port
KEYCLOAK_PORT=8080    # Keycloak admin console + OIDC endpoint
API_PORT=3001         # REST API + WebSocket
WEB_PORT=5173         # Web frontend (nginx serving the SPA)

# ─── Database ─────────────────────────────────────────────────────────────────
# Required — no defaults. Used by docker-compose.yml only (mock mode has no DB).
POSTGRES_DB=nextride
POSTGRES_USER=nextride
POSTGRES_PASSWORD=nextride

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Set to "true" to run the Prisma seed script on first boot (full stack only).
SEED=false
