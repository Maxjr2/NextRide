# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001        # Port the API server listens on
LOG_LEVEL=info

# ─── Mock Mode ────────────────────────────────────────────────────────────────
# Set to "true" to run without a real database or Keycloak.
# All data is stored in memory and resets on restart.
MOCK_MODE=false

# ─── Database (Postgres via Prisma) ───────────────────────────────────────────
DATABASE_URL="postgresql://nextride:nextride@localhost:5432/nextride?schema=public"

# ─── Auth (Keycloak) ──────────────────────────────────────────────────────────
KEYCLOAK_ISSUER=http://localhost:8080/realms/nextride
KEYCLOAK_AUDIENCE=nextride-api
# JWKS endpoint is derived from KEYCLOAK_ISSUER automatically

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Notifications ────────────────────────────────────────────────────────────
# Leave empty to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NextRide <noreply@nextride.local>"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
