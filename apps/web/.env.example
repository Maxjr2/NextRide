# Set to "true" to run without Keycloak — uses pre-seeded mock users
VITE_MOCK_MODE=false

# API base URL (proxied via Vite in dev, set explicitly for production builds)
VITE_API_URL=http://localhost:3001

# Keycloak settings (ignored when VITE_MOCK_MODE=true)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=nextride
VITE_KEYCLOAK_CLIENT_ID=nextride-web
